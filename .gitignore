# ── Secrets — never back these up to a remote ──
.env
*.key

# ── Regenerable / reinstallable — excluded from backup by design ──
# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
build/
dist/
.pytest_cache/
# Web build output + dependencies (recreate with `npm install` / `next build`)
web/.next/
web/node_modules/
web/out/
# Test/render artifacts (regenerated by tests/test_render.py)
out/
# OS / temp
.DS_Store
*.tmp

# ── Large source assets — excluded from git (too big; keep a separate local backup) ──
# Textbook PDFs (~1.5 GB). Authoring source only; do NOT commit.
/textbooks/

# NOTE: everything under data/ (constitutions, chapters, framework, saved plans, and
# per-user/tenant runtime state) is now TRACKED so GitHub Desktop backs it up. Only
# /textbooks/ and the regenerable/secret items above are excluded.

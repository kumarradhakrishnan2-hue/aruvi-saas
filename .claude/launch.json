{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "aruvi-api",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "api.main:app", "--port", "8000"],
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "aruvi-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev"],
      "port": 3000,
      "autoPort": false
    }
  ]
}
